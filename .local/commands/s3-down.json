{
  "name": "s3-down",
  "description": "Stop S3 stack",
  "steps": [
    {
      "type": "check",
      "command": "docker info",
      "error": "Docker daemon is not running"
    },
    {
      "type": "print",
      "text": "[s3] Stopping stack ..."
    },
    {
      "type": "shell",
      "tag": "s3",
      "command": "docker rm -f nextra-s3server 2>/dev/null || true"
    },
    {
      "type": "shell",
      "tag": "s3",
      "command": "docker rm -f nextra-s3server-db 2>/dev/null || true"
    },
    {
      "type": "print",
      "text": "[s3] Stack stopped"
    }
  ]
}
