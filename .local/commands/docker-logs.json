{
  "name": "docker-logs",
  "description": "Tail service logs",
  "steps": [
    {
      "type": "check",
      "command": "docker info",
      "error": "Docker daemon is not running"
    },
    {
      "type": "print",
      "text": "[docker] Tailing service logs"
    },
    {
      "type": "shell",
      "tag": "docker",
      "command": "docker compose logs -f --tail=100"
    }
  ]
}
