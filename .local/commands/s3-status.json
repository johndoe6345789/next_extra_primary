{
  "name": "s3-status",
  "description": "Show S3 stack status",
  "steps": [
    {
      "type": "check",
      "command": "docker info",
      "error": "Docker daemon is not running"
    },
    {
      "type": "capture",
      "command": "docker inspect -f '{{.State.Status}}' nextra-s3server 2>/dev/null || echo 'not found'",
      "var": "app_state"
    },
    {
      "type": "print",
      "text": "[s3] nextra-s3server:    {app_state}"
    },
    {
      "type": "capture",
      "command": "docker inspect -f '{{.State.Status}}' nextra-s3server-db 2>/dev/null || echo 'not found'",
      "var": "db_state"
    },
    {
      "type": "print",
      "text": "[s3] nextra-s3server-db: {db_state}"
    },
    {
      "type": "print",
      "text": "[s3] API: http://localhost:9000"
    }
  ]
}
