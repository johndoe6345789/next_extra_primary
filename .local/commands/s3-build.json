{
  "name": "s3-build",
  "description": "Build S3 server Docker image",
  "steps": [
    {
      "type": "check",
      "command": "docker info",
      "error": "Docker daemon is not running"
    },
    {
      "type": "print",
      "text": "[s3] Building S3 server image ..."
    },
    {
      "type": "shell",
      "tag": "s3",
      "command": "docker build -t nextra-s3server -f tools/s3server/backend/Dockerfile tools/s3server"
    }
  ]
}
