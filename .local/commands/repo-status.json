{
  "name": "repo-status",
  "description": "Show package repo stack status",
  "steps": [
    {
      "type": "check",
      "command": "docker info",
      "error": "Docker daemon is not running"
    },
    {
      "type": "capture",
      "command": "docker inspect -f '{{.State.Status}}' nextra-packagerepo 2>/dev/null || echo 'not found'",
      "variable": "repo_state"
    },
    {
      "type": "capture",
      "command": "docker inspect -f '{{.State.Status}}' nextra-packagerepo-db 2>/dev/null || echo 'not found'",
      "variable": "db_state"
    },
    {
      "type": "print",
      "text": "[repo] nextra-packagerepo: {repo_state}"
    },
    {
      "type": "print",
      "text": "[repo] nextra-packagerepo-db: {db_state}"
    },
    {
      "type": "print",
      "text": "[repo] API URL: http://localhost:5050"
    }
  ]
}
