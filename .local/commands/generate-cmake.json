{
  "name": "generate-cmake",
  "description": "Generate CMakeLists.txt from templates",
  "steps": [
    {
      "type": "print",
      "text": "[generate] Generating CMakeLists.txt ..."
    },
    {
      "type": "check",
      "command": "test -d tools/manager/templates",
      "error": "Templates directory not found: tools/manager/templates"
    },
    {
      "type": "template",
      "input": "tools/manager/project.json",
      "templates": "tools/manager/templates",
      "output": "."
    },
    {
      "type": "print",
      "text": "[generate] CMakeLists.txt generated."
    }
  ]
}
