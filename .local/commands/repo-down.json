{
  "name": "repo-down",
  "description": "Stop package repo stack",
  "steps": [
    {
      "type": "check",
      "command": "docker info",
      "error": "Docker daemon is not running"
    },
    {
      "type": "print",
      "text": "[repo] Stopping stack ..."
    },
    {
      "type": "shell",
      "tag": "repo",
      "command": "docker rm -f nextra-packagerepo"
    },
    {
      "type": "shell",
      "tag": "repo",
      "command": "docker rm -f nextra-packagerepo-db"
    }
  ]
}
