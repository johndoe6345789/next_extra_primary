{
  "name": "repo-build",
  "description": "Build package repo Docker image",
  "steps": [
    {
      "type": "check",
      "command": "docker info",
      "error": "Docker daemon is not running"
    },
    {
      "type": "print",
      "text": "[repo] Building backend image ..."
    },
    {
      "type": "shell",
      "tag": "repo",
      "command": "docker build -t nextra-packagerepo -f tools/packagerepo/backend/Dockerfile tools/packagerepo"
    }
  ]
}
