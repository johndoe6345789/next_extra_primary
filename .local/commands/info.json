{
  "name": "info",
  "description": "Show build environment info",
  "steps": [
    { "type": "print", "text": "[info] Platform:  {host_platform}" },
    { "type": "print", "text": "[info] Arch:      {host_arch}" },
    { "type": "print", "text": "[info] Registry:  {registry}" },
    { "type": "print", "text": "[info] SHA:       {sha}" },
    { "type": "print", "text": "[info] Repo root: {repo_root}" },
    { "type": "capture", "command": "node --version", "var": "node_ver" },
    { "type": "print", "text": "[info] Node:      {node_ver}" },
    { "type": "capture", "command": "docker --version", "var": "docker_ver" },
    { "type": "print", "text": "[info] Docker:    {docker_ver}" }
  ]
}
