{
  "name": "docker-down",
  "description": "Stop services",
  "steps": [
    {
      "type": "check",
      "command": "docker info",
      "error": "Docker daemon is not running"
    },
    {
      "type": "print",
      "text": "[docker] Stopping services"
    },
    {
      "type": "shell",
      "tag": "docker",
      "command": "docker compose down"
    }
  ]
}
