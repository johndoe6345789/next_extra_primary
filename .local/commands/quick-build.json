{
  "name": "quick-build",
  "description": "Build frontend and backend Docker images",
  "options": [
    { "name": "target", "default": "all", "help": "frontend|backend|all" },
    { "name": "platform", "default": "", "help": "Target platform" }
  ],
  "steps": [
    { "type": "check", "command": "docker info", "error": "Docker daemon is not running" },
    { "type": "set", "var": "plat", "value": "{opt.platform}", "default": "{host_platform}" },
    { "type": "print", "text": "[build] Target: {opt.target}  Platform: {plat}" },
    {
      "type": "shell",
      "tag": "frontend",
      "command": "docker buildx build --platform {plat} -t {registry}/frontend:{sha} ./frontend",
      "when": "{opt.target}"
    },
    {
      "type": "shell",
      "tag": "backend",
      "command": "docker buildx build --platform {plat} -t {registry}/backend:{sha} --build-context manager=./tools/manager ./backend",
      "when": "{opt.target}"
    }
  ]
}
