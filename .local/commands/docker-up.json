{
  "name": "docker-up",
  "description": "Start services (detached)",
  "steps": [
    {
      "type": "check",
      "command": "docker info",
      "error": "Docker daemon is not running"
    },
    {
      "type": "print",
      "text": "[docker] Starting services"
    },
    {
      "type": "shell",
      "tag": "docker",
      "command": "docker compose up -d"
    }
  ]
}
