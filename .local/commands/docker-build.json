{
  "name": "docker-build",
  "description": "Build Docker compose images",
  "steps": [
    {
      "type": "check",
      "command": "docker info",
      "error": "Docker daemon is not running"
    },
    {
      "type": "print",
      "text": "[docker] Building compose images"
    },
    {
      "type": "shell",
      "tag": "docker",
      "command": "docker compose build"
    }
  ]
}
