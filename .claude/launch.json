{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "portal",
      "runtimeExecutable": "docker",
      "runtimeArgs": ["compose", "up", "portal"],
      "port": 8888,
      "autoPort": false,
      "cwd": "."
    },
    {
      "name": "Nginx",
      "runtimeExecutable": "docker",
      "runtimeArgs": ["run", "--rm", "-p", "8889:80", "nginx:alpine"],
      "port": 8889,
      "autoPort": true
    }
  ]
}
