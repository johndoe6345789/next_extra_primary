{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "portal",
      "runtimeExecutable": "docker",
      "runtimeArgs": [
        "compose", "up", "--no-deps",
        "frontend", "portal"
      ],
      "port": 8889,
      "autoPort": false,
      "cwd": "."
    },
    {
      "name": "emailclient",
      "runtimeExecutable": "npx",
      "runtimeArgs": [
        "next", "dev",
        "--turbopack",
        "--port", "3200"
      ],
      "port": 3200,
      "cwd": "tools/emailclient"
    }
  ]
}
