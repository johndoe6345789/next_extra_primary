{
  "redis": {
    "default_host": "redis",
    "default_port": 6379,
    "connection_pool_size": 8,
    "connect_timeout_ms": 2000,
    "command_timeout_ms": 1000,
    "key_prefix": "nextra:"
  },
  "kafka": {
    "default_bootstrap_servers": "kafka:9092",
    "client_id_prefix": "nextra-",
    "default_acks": "all",
    "default_compression": "lz4",
    "default_retries": 5,
    "default_linger_ms": 5,
    "consumer_group_prefix": "nextra-",
    "session_timeout_ms": 10000,
    "default_topic_config": {
      "num_partitions": 3,
      "replication_factor": 1,
      "retention_ms": 604800000
    },
    "topics": {
      "audit_events": "nextra.audit.events",
      "email_outbound": "nextra.email.outbound",
      "gamification": "nextra.gamification.events",
      "notifications": "nextra.notifications"
    }
  }
}
