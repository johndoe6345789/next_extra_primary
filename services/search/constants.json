{
  "esHost": "elasticsearch",
  "esPort": 9200,
  "batchSize": 500,
  "reindexIntervalSeconds": 3600,
  "kafkaTopic": "search.reindex",
  "kafkaGroup": "search-indexer",
  "httpPort": 8086,
  "indexes": [
    {
      "name": "forum_posts",
      "targetTable": "comments_v2",
      "esIndex": "nextra-forum",
      "fields": ["id", "target_type", "target_id",
                 "author_id", "body", "title",
                 "created_at"],
      "idField": "id"
    },
    {
      "name": "wiki_pages",
      "targetTable": "wiki_pages",
      "esIndex": "nextra-wiki",
      "fields": ["id", "slug", "title", "body_md",
                 "updated_at"],
      "idField": "id"
    },
    {
      "name": "articles",
      "targetTable": "articles",
      "esIndex": "nextra-blog",
      "fields": ["id", "slug", "title", "body_md",
                 "author_id", "status",
                 "published_at"],
      "idField": "id"
    },
    {
      "name": "products",
      "targetTable": "products",
      "esIndex": "nextra-products",
      "fields": ["id", "sku", "name", "description",
                 "active"],
      "idField": "id"
    },
    {
      "name": "gallery_items",
      "targetTable": "galleries",
      "esIndex": "nextra-gallery",
      "fields": ["id", "slug", "title",
                 "description", "owner_id",
                 "created_at"],
      "idField": "id"
    },
    {
      "name": "users",
      "targetTable": "users",
      "esIndex": "nextra-users",
      "fields": ["id", "username", "email",
                 "display_name", "role"],
      "idField": "id"
    }
  ]
}
