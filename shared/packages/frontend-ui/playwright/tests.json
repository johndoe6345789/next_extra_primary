{
  "$schema": "https://metabuilder.dev/schemas/package-playwright.schema.json",
  "package": "frontend-ui",
  "description": "Frontend UI polish and interaction tests",
  "tests": [
    {
      "name": "landing page renders hero",
      "tags": ["@smoke", "@landing"],
      "steps": [
        { "action": "navigate",
          "url": "/app/en" },
        { "action": "waitForLoadState",
          "state": "domcontentloaded" },
        { "action": "expect",
          "testId": "hero-cta-start",
          "assertion": {
            "matcher": "toBeVisible"
          }
        },
        { "action": "expect",
          "testId": "hero-cta-learn",
          "assertion": {
            "matcher": "toBeVisible"
          }
        }
      ]
    },
    {
