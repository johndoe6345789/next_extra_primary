            "script": "(() => { const el = document.querySelector(\"[data-testid='locale-switcher'] [role='listbox']\"); const r = el.getBoundingClientRect(); return r.bottom > 0 && r.top < window.innerHeight; })()"
          }
        }
      ]
    },
    {
      "name": "locale switcher arrow rotates when open",
      "tags": ["@i18n", "@style"],
      "steps": [
        { "action": "navigate", "url": "/app/en" },
        { "action": "waitForLoadState", "state": "domcontentloaded" },
        { "action": "waitForElement",
          "selector": "[data-testid='locale-switcher'] [role='combobox']",
          "state": "visible" },
        { "action": "expect",
          "selector": "[data-testid='locale-switcher'] [role='combobox']",
          "assertion": {
            "matcher": "custom",
            "script": "(() => { const el = document.querySelector(\"[data-testid='locale-switcher'] [role='combobox']\"); if (!el) return false; const svg = el.querySelector('svg'); if (!svg) return false; const t = window.getComputedStyle(svg.parentElement).transform; return t === 'none' || t === 'matrix(1, 0, 0, 1, 0, 0)'; })()"
          }
        },
        { "action": "click",
          "selector": "[data-testid='locale-switcher'] [role='combobox']" },
        { "action": "expect",
          "selector": "[data-testid='locale-switcher'] [role='listbox']",
          "assertion": { "matcher": "toBeVisible" }
        },
        { "action": "wait", "timeout": 350 },
        { "action": "expect",
          "selector": "[data-testid='locale-switcher'] [role='combobox']",
          "assertion": {
            "matcher": "custom",
            "script": "(() => { const el = document.querySelector(\"[data-testid='locale-switcher'] [role='combobox']\"); if (!el) return false; const svg = el.querySelector('svg'); if (!svg) return false; const t = window.getComputedStyle(svg.parentElement).transform; return t !== 'none' && t !== 'matrix(1, 0, 0, 1, 0, 0)'; })()"
          }
        }
      ]
    },
