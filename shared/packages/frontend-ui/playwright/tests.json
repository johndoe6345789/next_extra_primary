          "assertion": { "matcher": "toBeVisible" }
        },
        { "action": "expect",
          "selector": "[data-testid='locale-switcher-en']",
          "assertion": {
            "matcher": "custom",
            "script": "(() => { const el = document.querySelector(\"[data-testid='locale-switcher-en']\"); return el.getBoundingClientRect().height >= 24; })()"
          }
        }
      ]
    },
