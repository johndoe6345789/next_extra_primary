    {
      "name": "locale switcher pill shape in light mode",
      "tags": ["@i18n", "@style"],
      "steps": [
        { "action": "navigate",
          "url": "/app/en" },
        { "action": "waitForLoadState",
          "state": "domcontentloaded" },
        { "action": "expect",
          "testId": "locale-switcher",
          "assertion": {
            "matcher": "toHaveCSS",
            "property": "border-radius",
            "value": "4px"
          }
        },
        { "action": "expect",
          "selector": "[data-testid='locale-switcher'] [role='combobox']",
          "assertion": {
            "matcher": "toHaveCSS",
            "property": "border-radius",
            "value": "4px"
          }
        }
      ]
    },
    {
      "name": "locale switcher trigger has correct padding",
      "tags": ["@i18n", "@style"],
      "steps": [
        { "action": "navigate",
          "url": "/app/en" },
        { "action": "waitForLoadState",
          "state": "domcontentloaded" },
        { "action": "expect",
          "selector": "[data-testid='locale-switcher'] [role='combobox']",
          "assertion": {
            "matcher": "toHaveCSS",
            "property": "padding-top",
            "value": "4px"
          }
        },
        { "action": "expect",
          "selector": "[data-testid='locale-switcher'] [role='combobox']",
          "assertion": {
            "matcher": "toHaveCSS",
