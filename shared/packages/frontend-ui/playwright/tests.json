      "name": "locale switcher dropdown panel is wide enough for items",
      "tags": ["@i18n", "@style"],
      "steps": [
        { "action": "navigate", "url": "/app/en" },
        { "action": "waitForLoadState", "state": "domcontentloaded" },
        { "action": "click",
          "selector": "[data-testid='locale-switcher'] [role='combobox']" },
