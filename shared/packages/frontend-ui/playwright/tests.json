    {
      "name": "locale switcher dropdown panel is not clipped by navbar",
      "tags": ["@i18n", "@style"],
      "steps": [
        { "action": "navigate", "url": "/app/en" },
        { "action": "waitForLoadState", "state": "domcontentloaded" },
        { "action": "click",
