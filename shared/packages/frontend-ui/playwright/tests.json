    {
      "name": "locale switcher has visible border in light mode",
      "tags": ["@i18n", "@style"],
      "steps": [
        { "action": "navigate",
          "url": "/app/en" },
        { "action": "waitForLoadState",
          "state": "domcontentloaded" },
        { "action": "expect",
          "testId": "locale-pill",
          "assertion": {
            "matcher": "toHaveCSS",
            "property": "border-style",
            "value": "solid"
          }
        }
      ]
    },
    {
      "name": "locale switcher dark mode text is readable",
      "tags": ["@i18n", "@style", "@dark"],
      "steps": [
        { "action": "navigate",
          "url": "/app/en" },
        { "action": "waitForLoadState",
          "state": "domcontentloaded" },
        { "action": "evaluate",
          "script": "document.documentElement.setAttribute('data-theme', 'dark')" },
        { "action": "expect",
          "testId": "locale-switcher",
          "assertion": {
            "matcher": "toBeVisible"
          }
        },
        { "action": "expect",
          "selector": "[data-testid='locale-switcher'] [role='combobox']",
          "assertion": {
            "matcher": "custom",
            "script": "(() => { const el = document.querySelector(\"[data-testid='locale-switcher'] [role='combobox']\"); const color = window.getComputedStyle(el).color; return color !== 'rgba(0, 0, 0, 0)' && color !== ''; })()"
          }
        }
      ]
    },
    {
      "name": "locale switcher dropdown panel has opaque background",
      "tags": ["@i18n", "@style"],
      "steps": [
        { "action": "navigate", "url": "/app/en" },
        { "action": "waitForLoadState", "state": "domcontentloaded" },
        { "action": "click", "selector": "[data-testid='locale-switcher'] [role='combobox']" },
        { "action": "expect",
          "selector": "[data-testid='locale-switcher'] [role='listbox']",
          "assertion": { "matcher": "toBeVisible" }
        },
        { "action": "expect",
          "selector": "[data-testid='locale-switcher'] [role='listbox']",
          "assertion": {
            "matcher": "custom",
            "script": "(() => { const panel = document.querySelector(\"[data-testid='locale-switcher'] [role='listbox']\"); const bg = window.getComputedStyle(panel).backgroundColor; if (bg === 'rgba(0, 0, 0, 0)' || bg === 'transparent') return false; const body = window.getComputedStyle(document.body).backgroundColor; return bg === body || bg !== 'rgb(255, 255, 255)'; })()"
          }
        }
      ]
    },
    {
      "name": "locale switcher dropdown panel stacks above page",
      "tags": ["@i18n", "@style"],
      "steps": [
        { "action": "navigate", "url": "/app/en" },
        { "action": "waitForLoadState", "state": "domcontentloaded" },
        { "action": "click", "selector": "[data-testid='locale-switcher'] [role='combobox']" },
        { "action": "expect",
          "selector": "[data-testid='locale-switcher'] [role='listbox']",
          "assertion": {
            "matcher": "toBeVisible"
          }
        },
        { "action": "expect",
          "selector": "[data-testid='locale-switcher'] .menuWrapper",
          "assertion": {
            "matcher": "custom",
            "script": "(() => { const el = document.querySelector(\"[data-testid='locale-switcher'] > div:last-child\"); const z = parseInt(window.getComputedStyle(el).zIndex); return z >= 1000; })()"
          }
        }
      ]
    },
    {
      "name": "locale switcher dropdown items have sufficient height",
      "tags": ["@i18n", "@style"],
      "steps": [
        { "action": "navigate", "url": "/app/en" },
        { "action": "waitForLoadState", "state": "domcontentloaded" },
        { "action": "click", "selector": "[data-testid='locale-switcher'] [role='combobox']" },
        { "action": "expect",
