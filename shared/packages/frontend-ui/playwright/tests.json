{
  "$schema": "https://metabuilder.dev/schemas/package-playwright.schema.json",
  "package": "frontend-ui",
  "description": "Frontend UI polish and interaction tests",
  "tests": [
    {
      "name": "landing page renders hero",
      "tags": ["@smoke", "@landing"],
      "steps": [
        { "action": "navigate",
          "url": "/app/en" },
        { "action": "waitForLoadState",
          "state": "domcontentloaded" },
        { "action": "expect",
          "testId": "hero-cta-start",
          "assertion": {
            "matcher": "toBeVisible"
          }
        },
        { "action": "expect",
          "testId": "hero-cta-learn",
          "assertion": {
            "matcher": "toBeVisible"
          }
        }
      ]
    },
    {
      "name": "feature grid shows 6 cards",
      "tags": ["@smoke", "@landing"],
      "steps": [
        { "action": "navigate",
          "url": "/app/en" },
        { "action": "waitForLoadState",
          "state": "domcontentloaded" },
        { "action": "expect",
          "testId": "feature-grid",
          "assertion": {
            "matcher": "toBeVisible"
          }
        },
        { "action": "expect",
          "selector": "[role='listitem']",
          "assertion": {
            "matcher": "toHaveCount",
            "count": 6
          }
        }
      ]
    },
    {
      "name": "burger opens drawer",
      "tags": ["@smoke", "@nav"],
      "steps": [
        { "action": "navigate",
          "url": "/app/en" },
        { "action": "waitForLoadState",
          "state": "domcontentloaded" },
        { "action": "click",
          "testId": "navbar-hamburger" },
        { "action": "expect",
          "testId": "navbar-drawer",
          "assertion": {
            "matcher": "toBeVisible"
          }
        }
      ]
    },
    {
      "name": "drawer links navigate",
      "tags": ["@nav"],
      "steps": [
        { "action": "navigate",
          "url": "/app/en" },
        { "action": "waitForLoadState",
          "state": "domcontentloaded" },
        { "action": "click",
          "testId": "navbar-hamburger" },
        { "action": "click",
          "role": "menuitem",
          "text": "About" },
        { "action": "waitForLoadState",
          "state": "networkidle" },
        { "action": "expect",
          "selector": "body",
          "assertion": {
            "matcher": "toHaveURL",
            "url": "/app/en/about"
          }
        }
      ]
    },
    {
      "name": "get started navigates to register",
      "tags": ["@smoke", "@nav"],
      "steps": [
        { "action": "navigate",
          "url": "/app/en" },
        { "action": "waitForLoadState",
          "state": "domcontentloaded" },
        { "action": "click",
          "testId": "hero-cta-start" },
        { "action": "waitForLoadState",
          "state": "networkidle" },
        { "action": "expect",
          "selector": "body",
          "assertion": {
            "matcher": "toHaveURL",
            "url": "/app/en/register"
          }
        }
      ]
    },
    {
      "name": "explore features scrolls to grid",
      "tags": ["@landing"],
      "steps": [
        { "action": "navigate",
          "url": "/app/en" },
        { "action": "waitForLoadState",
          "state": "domcontentloaded" },
        { "action": "click",
          "testId": "hero-cta-learn" },
        { "action": "expect",
          "testId": "feature-grid",
          "assertion": {
            "matcher": "toBeInViewport"
          }
        }
      ]
    },
    {
      "name": "locale switcher changes language",
      "tags": ["@smoke", "@i18n"],
      "steps": [
        { "action": "navigate",
          "url": "/app/en" },
        { "action": "waitForLoadState",
          "state": "domcontentloaded" },
        { "action": "click",
          "testId": "locale-switcher" },
        { "action": "click",
          "testId": "locale-switcher-es" },
        { "action": "waitForLoadState",
          "state": "networkidle" },
        { "action": "expect",
          "selector": "body",
          "assertion": {
            "matcher": "toHaveURL",
            "url": "/app/es"
          }
        }
      ]
    },
    {
      "name": "locale switcher pill shape in light mode",
      "tags": ["@i18n", "@style"],
      "steps": [
        { "action": "navigate",
          "url": "/app/en" },
        { "action": "waitForLoadState",
          "state": "domcontentloaded" },
        { "action": "expect",
          "testId": "locale-switcher",
          "assertion": {
            "matcher": "toHaveCSS",
            "property": "border-radius",
            "value": "4px"
          }
        },
        { "action": "expect",
          "selector": "[data-testid='locale-switcher'] [role='combobox']",
          "assertion": {
            "matcher": "toHaveCSS",
            "property": "border-radius",
            "value": "4px"
          }
        }
      ]
    },
    {
      "name": "locale switcher trigger has correct padding",
      "tags": ["@i18n", "@style"],
      "steps": [
        { "action": "navigate",
          "url": "/app/en" },
        { "action": "waitForLoadState",
          "state": "domcontentloaded" },
        { "action": "expect",
          "selector": "[data-testid='locale-switcher'] [role='combobox']",
          "assertion": {
            "matcher": "toHaveCSS",
            "property": "padding-top",
            "value": "4px"
          }
        },
        { "action": "expect",
          "selector": "[data-testid='locale-switcher'] [role='combobox']",
          "assertion": {
            "matcher": "toHaveCSS",
            "property": "padding-bottom",
            "value": "4px"
          }
        }
      ]
    },
    {
      "name": "locale switcher has visible border in light mode",
      "tags": ["@i18n", "@style"],
      "steps": [
        { "action": "navigate",
          "url": "/app/en" },
        { "action": "waitForLoadState",
          "state": "domcontentloaded" },
        { "action": "expect",
          "testId": "locale-pill",
          "assertion": {
            "matcher": "toHaveCSS",
            "property": "border-style",
            "value": "solid"
          }
        }
      ]
    },
    {
      "name": "locale switcher dark mode text is readable",
      "tags": ["@i18n", "@style", "@dark"],
      "steps": [
        { "action": "navigate",
          "url": "/app/en" },
        { "action": "waitForLoadState",
          "state": "domcontentloaded" },
        { "action": "evaluate",
          "script": "document.documentElement.setAttribute('data-theme', 'dark')" },
        { "action": "expect",
          "testId": "locale-switcher",
          "assertion": {
            "matcher": "toBeVisible"
          }
        },
        { "action": "expect",
          "selector": "[data-testid='locale-switcher'] [role='combobox']",
          "assertion": {
            "matcher": "custom",
            "script": "(() => { const el = document.querySelector(\"[data-testid='locale-switcher'] [role='combobox']\"); const color = window.getComputedStyle(el).color; return color !== 'rgba(0, 0, 0, 0)' && color !== ''; })()"
          }
        }
      ]
    },
    {
      "name": "locale switcher dropdown panel has opaque background",
      "tags": ["@i18n", "@style"],
      "steps": [
        { "action": "navigate", "url": "/app/en" },
        { "action": "waitForLoadState", "state": "domcontentloaded" },
        { "action": "click", "selector": "[data-testid='locale-switcher'] [role='combobox']" },
        { "action": "expect",
          "selector": "[data-testid='locale-switcher'] [role='listbox']",
          "assertion": {
            "matcher": "toBeVisible"
          }
        },
        { "action": "expect",
          "selector": "[data-testid='locale-switcher'] [role='listbox']",
          "assertion": {
            "matcher": "custom",
            "script": "(() => { const el = document.querySelector(\"[data-testid='locale-switcher'] [role='listbox']\"); const bg = window.getComputedStyle(el).backgroundColor; return bg !== 'rgba(0, 0, 0, 0)' && bg !== 'transparent'; })()"
          }
        }
      ]
    },
    {
      "name": "locale switcher dropdown panel stacks above page",
      "tags": ["@i18n", "@style"],
      "steps": [
        { "action": "navigate", "url": "/app/en" },
        { "action": "waitForLoadState", "state": "domcontentloaded" },
        { "action": "click", "selector": "[data-testid='locale-switcher'] [role='combobox']" },
        { "action": "expect",
          "selector": "[data-testid='locale-switcher'] [role='listbox']",
          "assertion": {
            "matcher": "toBeVisible"
          }
        },
        { "action": "expect",
          "selector": "[data-testid='locale-switcher'] .menuWrapper",
          "assertion": {
            "matcher": "custom",
            "script": "(() => { const el = document.querySelector(\"[data-testid='locale-switcher'] > div:last-child\"); const z = parseInt(window.getComputedStyle(el).zIndex); return z >= 1000; })()"
          }
        }
      ]
    },
    {
      "name": "locale switcher dropdown items have sufficient height",
      "tags": ["@i18n", "@style"],
      "steps": [
        { "action": "navigate", "url": "/app/en" },
        { "action": "waitForLoadState", "state": "domcontentloaded" },
        { "action": "click", "selector": "[data-testid='locale-switcher'] [role='combobox']" },
        { "action": "expect",
          "selector": "[data-testid='locale-switcher'] [role='listbox']",
          "assertion": { "matcher": "toBeVisible" }
        },
        { "action": "expect",
          "selector": "[data-testid='locale-switcher-en']",
          "assertion": {
            "matcher": "custom",
            "script": "(() => { const el = document.querySelector(\"[data-testid='locale-switcher-en']\"); return el.getBoundingClientRect().height >= 24; })()"
          }
        }
      ]
    },
    {
      "name": "login page renders 2-pane",
      "tags": ["@smoke", "@auth"],
      "steps": [
        { "action": "navigate",
          "url": "/app/en/login" },
        { "action": "waitForLoadState",
          "state": "domcontentloaded" },
        { "action": "expect",
          "role": "heading",
          "text": "Sign In",
          "assertion": {
            "matcher": "toBeVisible"
          }
        },
        { "action": "expect",
          "role": "textbox",
          "text": "Email",
          "assertion": {
            "matcher": "toBeVisible"
          }
        }
      ]
    },
    {
      "name": "login links work",
      "tags": ["@auth"],
      "steps": [
        { "action": "navigate",
          "url": "/app/en/login" },
        { "action": "waitForLoadState",
          "state": "domcontentloaded" },
        { "action": "click",
          "role": "link",
          "text": "Create Account" },
        { "action": "waitForLoadState",
          "state": "networkidle" },
        { "action": "expect",
          "selector": "body",
          "assertion": {
            "matcher": "toHaveURL",
            "url": "/app/en/register"
          }
        }
      ]
    },
    {
      "name": "about page renders content",
      "tags": ["@smoke", "@content"],
      "steps": [
        { "action": "navigate",
          "url": "/app/en/about" },
        { "action": "waitForLoadState",
          "state": "domcontentloaded" },
        { "action": "expect",
          "role": "heading",
          "text": "About",
          "assertion": {
            "matcher": "toBeVisible"
          }
        },
        { "action": "expect",
          "role": "heading",
          "text": "Our Mission",
          "assertion": {
            "matcher": "toBeVisible"
          }
        }
      ]
    },
    {
      "name": "contact page has form",
      "tags": ["@smoke", "@content"],
      "steps": [
        { "action": "navigate",
          "url": "/app/en/contact" },
        { "action": "waitForLoadState",
          "state": "domcontentloaded" },
        { "action": "expect",
          "role": "heading",
          "text": "Contact",
          "assertion": {
            "matcher": "toBeVisible"
          }
        },
        { "action": "expect",
          "role": "textbox",
          "text": "Name",
          "assertion": {
            "matcher": "toBeVisible"
          }
        }
      ]
    },
    {
      "name": "footer shows links",
      "tags": ["@smoke"],
      "steps": [
        { "action": "navigate",
          "url": "/app/en/about" },
        { "action": "waitForLoadState",
          "state": "domcontentloaded" },
        { "action": "expect",
          "role": "contentinfo",
          "assertion": {
            "matcher": "toBeVisible"
          }
        },
        { "action": "expect",
          "role": "link",
          "text": "About",
          "assertion": {
            "matcher": "toBeVisible"
          }
        }
      ]
    }
  ]
}
