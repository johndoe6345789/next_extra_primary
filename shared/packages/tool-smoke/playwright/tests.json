{
  "$schema": "https://metabuilder.dev/schemas/package-playwright.schema.json",
  "package": "tool-smoke",
  "description": "Smoke tests for project tools",
  "tests": [
    {
      "name": "S3 server login and bucket list",
      "tags": ["@smoke", "@tools"],
      "steps": [
        { "action": "navigate", "url": "http://localhost:9001" },
        { "action": "waitForLoadState", "state": "domcontentloaded" },
        { "action": "fill", "placeholder": "Username",
          "value": "minioadmin" },
        { "action": "fill", "placeholder": "Password",
          "value": "minioadmin" },
        { "action": "click", "role": "button", "text": "Login" },
        { "action": "waitForLoadState", "state": "networkidle" },
        { "action": "expect", "text": "Buckets",
          "assertion": { "matcher": "toBeVisible" } }
      ]
    },
    {
      "name": "package repo loads",
      "tags": ["@smoke", "@tools"],
      "steps": [
        { "action": "navigate", "url": "http://localhost:4873" },
        { "action": "waitForLoadState", "state": "domcontentloaded" },
        { "action": "expect", "selector": "body",
          "assertion": { "matcher": "toBeVisible" } },
        { "action": "expect", "selector": "body",
          "assertion": {
            "matcher": "toContainText",
            "expected": "Verdaccio"
          } }
      ]
    },
    {
      "name": "PgAdmin loads",
      "tags": ["@smoke", "@tools"],
      "steps": [
        { "action": "navigate", "url": "http://localhost:5050" },
        { "action": "waitForLoadState", "state": "domcontentloaded" },
        { "action": "expect", "selector": "body",
          "assertion": { "matcher": "toBeVisible" } },
        { "action": "expect", "selector": "body",
          "assertion": {
            "matcher": "toContainText",
            "expected": "pgAdmin"
          } }
      ]
    },
    {
      "name": "email client loads",
      "tags": ["@smoke", "@tools"],
      "steps": [
        { "action": "navigate", "url": "http://localhost:1080" },
        { "action": "waitForLoadState", "state": "domcontentloaded" },
        { "action": "expect", "selector": "body",
          "assertion": { "matcher": "toBeVisible" } },
        { "action": "expect", "selector": "body",
          "assertion": {
            "matcher": "toContainText",
            "expected": "Mail"
          } }
      ]
    },
    {
      "name": "alerts bell is an anchor not a button",
      "tags": ["@smoke", "@alerts", "@bugfix"],
      "steps": [
        { "action": "navigate",
          "url": "http://localhost:8889/emailclient" },
        { "action": "waitForLoadState",
          "state": "domcontentloaded" },
        { "action": "expect",
          "selector": "[data-testid='alerts-bell']",
          "assertion": { "matcher": "toBeVisible" } },
        { "action": "expect",
          "selector": "a[data-testid='alerts-bell']",
          "assertion": {
            "matcher": "toHaveAttribute",
            "name": "href",
            "value": "/alerts"
          } }
      ]
    },
    {
      "name": "alerts page renders M3 list (no raw <a>)",
      "tags": ["@smoke", "@alerts", "@bugfix"],
      "steps": [
        { "action": "navigate",
          "url": "http://localhost:8889/alerts" },
        { "action": "waitForLoadState",
          "state": "networkidle" },
        { "action": "expect",
          "selector": "[data-testid='alerts-heading']",
          "assertion": { "matcher": "toBeVisible" } },
        { "action": "expect",
          "selector":
            "[data-testid='alerts-list'], [data-testid='alerts-empty']",
          "assertion": { "matcher": "toBeVisible" } }
      ]
    },
    {
      "name": "alerts error surfaces M3 banner on API failure",
      "tags": ["@alerts", "@bugfix"],
      "steps": [
        { "action": "mockApi",
          "url": "**/alerts/api/email/accounts",
          "method": "GET",
          "status": 500,
          "response": {} },
        { "action": "navigate",
          "url": "http://localhost:8889/alerts" },
        { "action": "waitForLoadState",
          "state": "networkidle" },
        { "action": "expect",
          "selector": "[data-testid='alerts-error']",
          "assertion": { "matcher": "toBeVisible" } }
      ]
    },
    {
      "name": "email client star hits backend API",
      "tags": ["@emailclient", "@bugfix"],
      "steps": [
        { "action": "mockApi",
          "url": "**/emailclient/api/messages/*/star",
          "method": "PUT",
          "status": 200,
          "response": { "id": 1, "isStarred": true } },
        { "action": "navigate",
          "url": "http://localhost:8889/emailclient" },
        { "action": "waitForLoadState",
          "state": "networkidle" },
        { "action": "click",
          "selector": "[data-testid^='email-star-']",
          "optional": true },
        { "action": "expect",
          "selector": "body",
          "assertion": { "matcher": "toBeVisible" } }
      ]
    }
  ]
}
