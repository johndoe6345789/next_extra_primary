{
  "$schema": "https://metabuilder.dev/schemas/package-playwright.schema.json",
  "package": "portal-walkthrough",
  "description": "End-to-end walkthrough: portal homepage, SSO login, and every service UI",
  "tests": [
    {
      "name": "portal homepage renders all service cards",
      "tags": ["@portal", "@smoke"],
      "steps": [
        {
          "action": "navigate",
          "url": "http://localhost:8889/"
        },
        {
          "action": "waitForLoadState",
          "state": "domcontentloaded"
        },
        {
          "action": "expect",
          "selector": "h1",
          "assertion": {
            "matcher": "toContainText",
            "expected": "Nextra"
          }
        },
        {
          "action": "expect",
          "selector": "a[href='/app/']",
          "assertion": { "matcher": "toBeVisible" }
        },
        {
          "action": "expect",
          "selector": "a[href='/repo/']",
          "assertion": { "matcher": "toBeVisible" }
        },
        {
          "action": "expect",
          "selector": "a[href='/s3/']",
          "assertion": { "matcher": "toBeVisible" }
        },
        {
          "action": "expect",
          "selector": "a[href='/db/']",
          "assertion": { "matcher": "toBeVisible" }
        },
        {
          "action": "expect",
          "selector": "a[href='/emailclient/']",
          "assertion": { "matcher": "toBeVisible" }
        },
        {
          "action": "expect",
          "selector": "a[href='/alerts/']",
          "assertion": { "matcher": "toBeVisible" }
        }
      ]
    },
    {
      "name": "SSO login page renders",
