        {
          "action": "fill",
          "selector": "input[type='email']",
          "value": "dev.admin@nextra.local"
        },
        {
          "action": "fill",
          "selector": "input[type='password']",
          "value": "DevAdmin1"
        },
        {
          "action": "click",
          "role": "button",
          "text": "Sign in"
        },
        {
          "action": "waitForURL",
          "urlPattern": "**/app/**",
          "timeout": 15000
        },
        {
          "action": "expect",
          "selector": "body",
          "assertion": { "matcher": "toBeVisible" }
        }
      ]
    },
