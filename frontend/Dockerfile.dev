# Dev Dockerfile — runs `next dev` with Turbopack.
# All source baked in; rebuild image to pick up changes.
FROM node:22-slim
ARG NPM_REGISTRY=http://host.docker.internal:4873
ENV NPM_CONFIG_REGISTRY=$NPM_REGISTRY

# Mirror the monorepo layout so shared/ resolves
COPY --from=shared . /build/shared/
WORKDIR /build/app
COPY package.json package-lock.json* ./
RUN npm config set fetch-retries 5 \
  && npm config set fetch-retry-mintimeout 20000 \
  && npm config set fetch-retry-maxtimeout 120000 \
  && npm install --prefer-offline --no-audit --no-fund
RUN ln -s /build/app/node_modules /build/node_modules

COPY . .

ENV NEXT_TELEMETRY_DISABLED=1
ENV PORT=3000
ENV HOSTNAME="0.0.0.0"
EXPOSE 3000
CMD ["npx", "next", "dev", "--port", "3000"]
