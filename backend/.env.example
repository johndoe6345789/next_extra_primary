# =============================================================
# nextra-api  --  Environment Variables
# =============================================================
# Copy this file to .env and fill in the values for your
# deployment target.  Never commit the real .env file.
# =============================================================

# ----- Server ------------------------------------------------
# TCP port the API listens on (overrides config.json).
PORT=8080
# Path to the Drogon config file.
CONFIG_PATH=config/config.json

# ----- PostgreSQL --------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_NAME=nextra_db
DB_USER=nextra
DB_PASSWORD=

# ----- JWT ---------------------------------------------------
# HMAC-SHA256 secret used to sign access & refresh tokens.
# Generate with:  openssl rand -base64 64
JWT_SECRET=CHANGE_ME_IN_PRODUCTION
# Token lifetimes in seconds.
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=604800

# ----- SMTP (outbound e-mail) --------------------------------
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_ADDRESS=noreply@nextra.local
SMTP_FROM_NAME=Nextra
SMTP_USE_TLS=true

# ----- AI Providers ------------------------------------------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
AI_MAX_TOKENS=4096

# ----- CORS --------------------------------------------------
CORS_ORIGIN=http://localhost:3000

# ----- Logging -----------------------------------------------
# Drogon log levels: TRACE, DEBUG, INFO, WARN, ERROR, FATAL
LOG_LEVEL=INFO
LOG_PATH=./logs
