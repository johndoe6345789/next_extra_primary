{
  "realm": "nextra",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": true,
  "registrationEmailAsUsername": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,
  "loginTheme": "nextra",
  "attributes": {
    "frontendUrl": "http://localhost:8889/sso"
  },
  "verifyEmail": false,
  "webAuthnPolicyRpEntityName": "Nextra",
  "webAuthnPolicyRpId": "localhost",
  "webAuthnPolicySignatureAlgorithms": ["ES256", "RS256"],
  "webAuthnPolicyPasswordlessRpEntityName": "Nextra",
  "webAuthnPolicyPasswordlessRpId": "localhost",
  "webAuthnPolicyPasswordlessSignatureAlgorithms": ["ES256", "RS256"],
  "otpPolicyType": "totp",
  "otpPolicyAlgorithm": "HmacSHA1",
  "otpPolicyDigits": 6,
  "otpPolicyPeriod": 30,
  "otpPolicyInitialCounter": 0,
  "otpPolicyLookAheadWindow": 1,
  "requiredActions": [
    { "alias": "CONFIGURE_TOTP", "name": "Configure OTP",
      "providerId": "CONFIGURE_TOTP", "enabled": true,
      "defaultAction": false, "priority": 10, "config": {} },
    { "alias": "webauthn-register", "name": "Webauthn Register",
      "providerId": "webauthn-register", "enabled": true,
      "defaultAction": false, "priority": 70, "config": {} },
    { "alias": "webauthn-register-passwordless",
      "name": "Webauthn Register Passwordless",
      "providerId": "webauthn-register-passwordless",
      "enabled": true, "defaultAction": false,
      "priority": 80, "config": {} }
  ],
  "smtpServer": {
    "host": "mailserver",
    "port": "587",
    "from": "noreply@nextra.local",
    "fromDisplayName": "Nextra",
    "replyTo": "noreply@nextra.local",
    "ssl": "false",
    "starttls": "false",
    "auth": "false",
    "user": "",
    "password": ""
  },
  "identityProviders": [
    {
      "alias": "github",
      "providerId": "github",
      "enabled": false,
      "trustEmail": false,
      "storeToken": false,
      "addReadTokenRoleOnCreate": false,
      "firstBrokerLoginFlowAlias": "first broker login",
      "config": {
        "clientId": "${env.KC_GITHUB_CLIENT_ID:}",
        "clientSecret": "${env.KC_GITHUB_CLIENT_SECRET:}",
        "syncMode": "IMPORT"
      }
    },
    {
      "alias": "google",
      "providerId": "google",
      "enabled": false,
      "trustEmail": false,
      "storeToken": false,
      "addReadTokenRoleOnCreate": false,
      "firstBrokerLoginFlowAlias": "first broker login",
      "config": {
        "clientId": "${env.KC_GOOGLE_CLIENT_ID:}",
        "clientSecret": "${env.KC_GOOGLE_CLIENT_SECRET:}",
        "defaultScope": "openid email profile",
        "syncMode": "IMPORT"
      }
    },
    {
      "alias": "microsoft",
      "providerId": "microsoft",
      "enabled": false,
      "trustEmail": false,
      "storeToken": false,
      "addReadTokenRoleOnCreate": false,
      "firstBrokerLoginFlowAlias": "first broker login",
      "config": {
        "clientId": "${env.KC_MICROSOFT_CLIENT_ID:}",
        "clientSecret": "${env.KC_MICROSOFT_CLIENT_SECRET:}",
        "defaultScope": "openid email profile",
        "syncMode": "IMPORT"
      }
    }
  ],
  "roles": {
    "realm": [
      { "name": "admin",     "description": "Administrator role" },
      { "name": "moderator", "description": "Moderator role" },
      { "name": "user",      "description": "Standard user role" }
    ]
  },
  "clients": [
    {
      "clientId": "nextra-app",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "implicitFlowEnabled": false,
      "protocol": "openid-connect",
      "redirectUris": ["http://localhost:8889/*"],
      "webOrigins": ["http://localhost:8889"],
      "attributes": {
        "post.logout.redirect.uris": "http://localhost:8889/*"
      },
      "fullScopeAllowed": true
    }
  ],
  "users": [
    {
      "username": "devadmin",
      "email": "dev.admin@nextra.local",
      "firstName": "Dev",
      "lastName": "Admin",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        { "type": "password",
          "value": "DevAdmin1",
          "temporary": false }
      ],
      "realmRoles": ["admin", "user"]
    },
    {
      "username": "devuser",
      "email": "dev.user@nextra.local",
      "firstName": "Dev",
      "lastName": "User",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        { "type": "password",
          "value": "DevUser1",
          "temporary": false }
      ],
      "realmRoles": ["user"]
    },
    {
      "username": "devmod",
      "email": "dev.mod@nextra.local",
      "firstName": "Dev",
      "lastName": "Moderator",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        { "type": "password",
          "value": "DevMod1a",
          "temporary": false }
      ],
      "realmRoles": ["moderator", "user"]
    }
  ]
}
